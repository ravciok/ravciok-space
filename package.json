{
  "name": "ravciok-space",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production --stats-json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "scully": "npx scully --",
    "scully:serve": "npx scully serve --",
    "clear": "rm -rf dist content",
    "fetch": "npm run clear && node data/fetchData.js",
    "static": "npm run fetch && npm run build && npm run scully",
    "static:serve": "npm run static && npm run scully:serve"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "^12.2.3",
    "@angular/animations": "^12.2.3",
    "@angular/cli": "^12.2.3",
    "@angular/common": "^12.2.3",
    "@angular/compiler": "^12.2.3",
    "@angular/compiler-cli": "^12.2.3",
    "@angular/core": "^12.2.3",
    "@angular/forms": "^12.2.3",
    "@angular/platform-browser": "^12.2.3",
    "@angular/platform-browser-dynamic": "^12.2.3",
    "@angular/router": "^12.2.3",
    "@scullyio/init": "^1.1.4",
    "@scullyio/ng-lib": "^1.0.0",
    "@scullyio/scully": "^1.0.0",
    "dotenv": "^10.0.0",
    "reading-time": "^1.4.0",
    "rxjs": "~6.6.0",
    "scully-plugin-disable-angular": "^8.0.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@types/jasmine": "~3.8.0",
    "@types/node": "^12.20.21",
    "jasmine-core": "~3.8.0",
    "karma": "~6.3.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "prettier": "^2.3.2",
    "typescript": "~4.3.5"
  }
}
